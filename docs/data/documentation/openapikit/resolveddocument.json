{"schemaVersion":{"patch":0,"major":0,"minor":3},"relationshipsSections":[{"type":"conformsTo","kind":"relationships","identifiers":["doc:\/\/OpenAPIKit\/SQ"],"title":"Conforms To"}],"abstract":[{"type":"text","text":"A resolved document is a fully dereferenced"},{"type":"text","text":" "},{"type":"text","text":"OpenAPI document that has been further distilled"},{"type":"text","text":" "},{"type":"text","text":"to canonical representations of each component. You"},{"type":"text","text":" "},{"type":"text","text":"create a "},{"type":"codeVoice","code":"ResolvedDocument"},{"type":"text","text":" by calling the "},{"type":"codeVoice","code":"resolved()"},{"type":"text","text":" "},{"type":"text","text":"method on a "},{"type":"codeVoice","code":"DereferencedDocument"},{"type":"text","text":"."}],"variants":[{"paths":["\/documentation\/openapikit\/resolveddocument"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/ResolvedDocument"},"metadata":{"role":"symbol","symbolKind":"struct","modules":[{"name":"OpenAPIKit"}],"externalID":"s:10OpenAPIKit16ResolvedDocumentV","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ResolvedDocument","kind":"identifier"}],"navigatorTitle":[{"text":"ResolvedDocument","kind":"identifier"}],"title":"ResolvedDocument","roleHeading":"Structure"},"topicSections":[{"identifiers":["doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/ResolvedDocument\/endpoints","doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/ResolvedDocument\/paths","doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/ResolvedDocument\/routes","doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/ResolvedDocument\/routesByPath","doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/ResolvedDocument\/security","doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/ResolvedDocument\/underlyingDocument"],"title":"Instance Properties"},{"identifiers":["doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/ResolvedDocument\/subscript(dynamicMember:)"],"title":"Subscripts"},{"generated":true,"identifiers":["doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/ResolvedDocument\/Equatable-Implementations"],"title":"Default Implementations"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@dynamicMemberLookup"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ResolvedDocument"}],"languages":["swift"],"platforms":["Linux"]}],"kind":"declarations"},{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"inlineContent":[{"type":"text","text":"OpenAPI documents have two distinct forms of"},{"type":"text","text":" "},{"type":"text","text":"distributing information such that not all relevant"},{"type":"text","text":" "},{"type":"text","text":"bits of information are available in one structural"},{"type":"text","text":" "},{"type":"text","text":"part of an OpenAPI Document."}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Documents can contain references. This is great","type":"text"},{"text":" ","type":"text"},{"text":"because authors can make one part of an","type":"text"},{"text":" ","type":"text"},{"text":"OpenAPI document more concise by referencing","type":"text"},{"text":" ","type":"text"},{"text":"a component instead of writing it inline and it also","type":"text"},{"text":" ","type":"text"},{"text":"allows shared definitions to be re-used throughout","type":"text"},{"text":" ","type":"text"},{"text":"the document.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Documents can define and override certain things at","type":"text"},{"text":" ","type":"text"},{"text":"different levels of their structure. For example, a","type":"text"},{"text":" ","type":"text"},{"text":"document may define a shared set of Security","type":"text"},{"text":" ","type":"text"},{"text":"Requirements at the root and then override those","type":"text"},{"text":" ","type":"text"},{"text":"Security Requirements for particular Operations.","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"inlineContent":[{"text":"Both of these features of OpenAPI documents make it","type":"text"},{"text":" ","type":"text"},{"text":"impossible to answer certain questions about a particular","type":"text"},{"text":" ","type":"text"},{"text":"route or endpoint without looking to multiple disparate parts","type":"text"},{"text":" ","type":"text"},{"text":"of the document and then applying certain rules to determine","type":"text"},{"text":" ","type":"text"},{"text":"the relevant semantic definition of the route or endpoint being","type":"text"},{"text":" ","type":"text"},{"text":"studied.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"OpenAPIKit defines canonical forms (i.e. the only true definitions)"},{"type":"text","text":" "},{"type":"text","text":"of endpoints, routes, and the whole document. These types (named"},{"type":"text","text":" "},{"code":"ResolvedEndpoint","type":"codeVoice"},{"type":"text","text":", "},{"code":"ResolvedRoute","type":"codeVoice"},{"type":"text","text":", and "},{"code":"ResolvedDocument","type":"codeVoice"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"each allow you to get complete information about the respective components"},{"type":"text","text":" "},{"type":"text","text":"without looking to other parts of the document."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Example","type":"text"}],"type":"strong"}],"type":"paragraph"},{"inlineContent":[{"text":"You want to know what all of the parameters for a particular ","type":"text"},{"code":"PATCH","type":"codeVoice"},{"text":" endpoint are.","type":"text"},{"text":" ","type":"text"},{"text":"Without the ","type":"text"},{"code":"ResolvedEndpoint","type":"codeVoice"},{"text":" type, you would need to look at the","type":"text"},{"text":" ","type":"text"},{"code":"OpenAPI.Operation","type":"codeVoice"},{"text":" representing the endpoint, the ","type":"text"},{"code":"OpenAPI.PathItem","type":"codeVoice"},{"text":" ","type":"text"},{"text":"representing the route containing the endpoint, and you would need to potentially","type":"text"},{"text":" ","type":"text"},{"text":"resolve references to the ","type":"text"},{"code":"OpenAPI.Components","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"With ","type":"text"},{"code":"ResolvedDocument","type":"codeVoice"},{"text":", the same task is much simpler:","type":"text"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["let document: OpenAPI.Document = ...","","let resolvedDocument = try document","    .locallyDereferenced()","    .resolved()","","let endpoint = resolvedDocument","    .routesByPath[\"\/example\/path\"]!.patch!","","\/\/ This will be all parameters defined anywhere that","\/\/ apply to this endpoint:","let parameters = endpoint.parameters"]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit"]]},"references":{"doc://OpenAPIKit/documentation/OpenAPIKit/ResolvedDocument/Equatable-Implementations":{"role":"collectionGroup","type":"topic","abstract":[],"identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/ResolvedDocument\/Equatable-Implementations","kind":"article","url":"\/documentation\/openapikit\/resolveddocument\/equatable-implementations","title":"Equatable Implementations"},"doc://OpenAPIKit/documentation/OpenAPIKit/ResolvedDocument/routes":{"role":"symbol","abstract":[{"type":"text","text":"Get an array containing all routes in the document."}],"url":"\/documentation\/openapikit\/resolveddocument\/routes","type":"topic","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"routes","kind":"identifier"},{"text":": [","kind":"text"},{"text":"ResolvedRoute","kind":