lled","type":"text"},{"type":"text","text":" "},{"text":"to canonical representations of each component. You","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"create a "},{"type":"codeVoice","code":"ResolvedDocument"},{"text":" by calling the ","type":"text"},{"type":"codeVoice","code":"resolved()"},{"text":" ","type":"text"},{"text":"method on a ","type":"text"},{"type":"codeVoice","code":"DereferencedDocument"},{"text":".","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ResolvedDocument"}],"navigatorTitle":[{"kind":"identifier","text":"ResolvedDocument"}],"role":"symbol","type":"topic","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/ResolvedDocument","title":"ResolvedDocument","url":"\/documentation\/openapikit\/resolveddocument","kind":"symbol"}}}