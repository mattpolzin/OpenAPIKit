de what decoder to use and provide the file data to that","type":"text"},{"text":" ","type":"text"},{"text":"decoder. See ","type":"text"},{"type":"codeVoice","code":"ExternalLoader"},{"text":" documentation for details.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://OpenAPIKit/documentation/OpenAPIKit/ExternalLoader/Message":{"kind":"symbol","type":"topic","fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Message","kind":"identifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:s8SendableP","text":"Sendable","kind":"typeIdentifier"}],"identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/ExternalLoader\/Message","required":true,"url":"\/documentation\/openapikit\/externalloader\/message","title":"Message","role":"symbol","abstract":[{"text":"This can be anything that an implementor of this protocol wants to pass back from","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"codeVoice","code":"load()"},{"text":" function and have available after all external loading has been done.","type":"text"}]},"doc://OpenAPIKit/documentation/OpenAPIKit":{"abstract":[],"identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit","title":"OpenAPIKit","url":"\/documentation\/openapikit","type":"topic","role":"collection","kind":"symbol"},"doc://OpenAPIKit/documentation/OpenAPIKit/ExternalLoader":{"kind":"symbol","type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ExternalLoader","kind":"identifier"}],"identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/ExternalLoader","navigatorTitle":[{"text":"ExternalLoader","kind":"identifier"}],"url":"\/documentation\/openapikit\/externalloader","title":"ExternalLoader","role":"symbol","abstract":[{"text":"An ","type":"text"},{"code":"ExternalLoader","type":"codeVoice"},{"text":" enables ","type":"text"},{"code":"OpenAPIKit","type":"codeVoice"},{"text":" to load external r