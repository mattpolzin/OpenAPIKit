ext":"@discardableResult","kind":"attribute"},{"text":" ","kind":"text"},{"text":"mutating","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"externallyDereference","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Loader","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"with","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"loader","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Loader","kind":"typeIdentifier"},{"text":".Type, ","kind":"text"},{"text":"depth","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10OpenAPIKit24ExternalDereferenceDepthO","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/ExternalDereferenceDepth","text":"ExternalDereferenceDepth","kind":"typeIdentifier"},{"text":" = .iterations(1), ","kind":"text"},{"text":"context","kind":"externalParam"},{"text":": [","kind":"text"},{"text":"Loader","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:10OpenAPIKit14ExternalLoaderP7MessageQa","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/ExternalLoader\/Message","text":"Message","kind":"typeIdentifier"},{"text":"] = []) ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> [","kind":"text"},{"text":"Loader","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:10OpenAPIKit14ExternalLoaderP7MessageQa","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/ExternalLoader\/Message","text":"Message","kind":"typeIdentifier"},{"text":"] ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Loader","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:10OpenAPIKit14ExternalLoaderP","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/ExternalLoader","text":"ExternalLoader","kind":"typeIdentifier"}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"This function will load remote references into the Components object"},{"type":"text","text":" "},{"type":"text","text":"and replace the remote reference with a local reference to that component."},{"type":"text","text":" "},{"type":"text","text":"No local references are modified or resolved by this function. You can"},{"type":"text","text":" "},{"type":"text","text":"call "},{"type":"codeVoice","code":"locallyDereferenced()"},{"type":"text","text":" on the externally dereferenced document if"},{"type":"text","text":" "},{"type":"text","text":"you want to also remove local references by inlining all of them."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Externally dereferencing a document requires that you provide both a"},{"type":"text","text":" "},{"type":"text","text":"function that produces a "},{"code":"OpenAPI.ComponentKey","type":"codeVoice"},{"type":"text","text":" for any given remote"},{"type":"text","text":" "},{"type":"text","text":"file URI and also a function that loads and decodes the data found in"},{"type":"text","text":" "},{"type":"text","text":"that remote file. The latter is less work than it may sound like because"},{"type":"text","text":" "},{"type":"text","text":"the function is told what Decodable thing it wants, so you really just"},{"type":"text","text":" "},{"type":"text","text":"need to decide what decoder to use and provide the file data to that"},{"type":"text","text":" "},{"type":"text","text":"decoder. See "},{"code":"ExternalLoader","type":"codeVoice"},{"type":"text","text":" documentation for details."}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Document\/externallyDereference(with:depth:context:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openapikit\/openapi\/documen