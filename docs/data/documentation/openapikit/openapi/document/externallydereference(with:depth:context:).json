role":"symbol","title":"ExternalLoader","abstract":[{"text":"An ","type":"text"},{"type":"codeVoice","code":"ExternalLoader"},{"text":" enables ","type":"text"},{"type":"codeVoice","code":"OpenAPIKit"},{"text":" to load external references","type":"text"},{"text":" ","type":"text"},{"text":"without knowing the details of what decoder is being used or how new internal","type":"text"},{"text":" ","type":"text"},{"text":"references should be named.","type":"text"}],"navigatorTitle":[{"text":"ExternalLoader","kind":"identifier"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/ExternalLoader","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ExternalLoader","kind":"identifier"}],"url":"\/documentation\/openapikit\/externalloader"},"doc://OpenAPIKit/documentation/OpenAPIKit/ExternalLoader/Message":{"role":"symbol","title":"Message","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/ExternalLoader\/Message","fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Message","kind":"identifier"},{"text":" : ","kind":"text"},{"text":"Sendable","preciseIdentifier":"s:s8SendableP","kind":"typeIdentifier"}],"type":"topic","kind":"symbol","required":true,"abstract":[{"text":"This can be anything that an implementor of this protocol wants to pass back from","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"load()","type":"codeVoice"},{"text":" function and have available after all external loading has been done.","type":"text"}],"url":"\/documentation\/openapikit\/externalloader\/message"}}}