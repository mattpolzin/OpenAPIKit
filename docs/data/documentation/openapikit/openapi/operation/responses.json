,"code":"Response"},{"type":"text","text":" or a reference to a "},{"type":"codeVoice","code":"Response"},{"type":"text","text":" that is"},{"type":"text","text":" "},{"type":"text","text":"defined elsewhere."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Example:","type":"text"}]}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["let firstResponse: (OpenAPI.Response.StatusCode, Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>)","firstResponse = operation.responses[0]!","","\/\/ literally documented as \"200\" status code:","let successResponse: Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>","successResponse = operation.responses[status: 200]!","","\/\/ documented as \"2XX\" status code:","let successResponse2: Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>","successResponse2 = operation.responses[.range(.success)]!"]},{"inlineContent":[{"text":"If you want to access the response (assuming it is inlined) you need to grab","type":"text"},{"text":" ","type":"text"},{"text":"it out of the ","type":"text"},{"code":"Either","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Example:"}],"type":"strong"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["let inlinedResponse = successResponse.responseValue"]},{"inlineContent":[{"type":"text","text":"You can also look the response up in the "},{"type":"codeVoice","code":"Components"},{"type":"text","text":". For convenience, you"},{"type":"text","text":" "},{"type":"text","text":"can ask to have the "},{"type":"codeVoice","code":"Either"},{"type":"text","text":" looked up and the result will be the "},{"type":"codeVoice","code":"Response"},{"type":"text","text":" "},{"type":"text","text":"regardless of whether the "},{"type":"codeVoice","code":"Response"},{"type":"text","text":" was inlined or found in the "},{"type":"codeVoice","code":"Components"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Example:","type":"text"}],"type":"strong"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["let foundResponse: OpenAPI.Response","foundResponse = document.components.lookup(successResponse)!"]}]}],"abstract":[{"text":"The possible responses for this operation, keyed by status code.","type":"text"}],"identifier":{"url":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Operation\/responses","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Instance Property","title":"responses","externalID":"s:10OpenAPIKit0A3APIO9OperationV9responses0aB4Core17OrderedDictionaryVyAG6SharedO18ResponseStatusCodeVAG6EitherOyAC9ReferenceVy_AC0J0VGASGGvp","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"responses","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10OpenAPIKit0A3APIO","text":"OpenAPI","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:10OpenAPIKit0A3APIO8ResponseV","text":"Response","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:10OpenAPIKit0A3APIO8ResponseV3Mapa","text":"Map","kind":"typeIdentifier"}],"symbolKind":"property","modules":[{"name":"OpenAPIKit"}],"role":"symbol"},"sections":[],"kind":"symbol","references":{"doc://OpenAPIKit/documentation/OpenAPIKit/OpenAPI/Operation":{"role":"symbol","url":"\/documentation\/openapikit\/openapi\/operation","title":"OpenAPI.Operation","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"Operation","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Operation","abstract":[{"text":"OpenAPI Spec “Operation Object”","type":"text"}],"navigatorTitle":[{"text":"Operation","kind":"identifier"}]},"doc://OpenAPIKit/documentation/OpenAPIKit/OpenAPI/Response/Map":{"navigatorTitle":[{"text":"Map","kind":"id