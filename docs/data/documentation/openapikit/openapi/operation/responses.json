e\/Map","preciseIdentifier":"s:10OpenAPIKit0A3APIO8ResponseV3Mapa","text":"Map","kind":"typeIdentifier"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The status code keys can be integer values, ranges, or even the"},{"type":"text","text":" "},{"type":"codeVoice","code":"default"},{"type":"text","text":" which just refers to the response to expect where no"},{"type":"text","text":" "},{"type":"text","text":"other respones apply."}]},{"type":"paragraph","inlineContent":[{"text":"Because the map is ordered, you can access responses by either","type":"text"},{"text":" ","type":"text"},{"text":"status code or index. Notice that the values of this dictionary are actually","type":"text"},{"text":" ","type":"text"},{"code":"Either","type":"codeVoice"},{"text":" an inline ","type":"text"},{"code":"Response","type":"codeVoice"},{"text":" or a reference to a ","type":"text"},{"code":"Response","type":"codeVoice"},{"text":" that is","type":"text"},{"text":" ","type":"text"},{"text":"defined elsewhere.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Example:","type":"text"}],"type":"strong"}]},{"type":"codeListing","code":["let firstResponse: (OpenAPI.Response.StatusCode, Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>)","firstResponse = operation.responses[0]!","","\/\/ literally documented as \"200\" status code:","let successResponse: Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>","successResponse = operation.responses[status: 200]!","","\/\/ documented as \"2XX\" status code:","let successResponse2: Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>","successResponse2 = operation.responses[.range(.success)]!"],"syntax":null},{"type":"paragraph","inlineContent":[{"text":"If you want to access the response (assuming it is inlined) you need to grab","type":"text"},{"text":" ","type":"text"},{"text":"it out of the ","type":"text"},{"code":"Either","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Example:","type":"text"}]}]},{"type":"codeListing","code":["let inlinedResponse = successResponse.responseValue"],"syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also look the response up in the "},{"code":"Components","type":"codeVoice"},{"type":"text","text":". For convenience, you"},{"type":"text","text":" "},{"type":"text","text":"can ask to have the "},{"code":"Either","type":"codeVoice"},{"type":"text","text":" looked up and the result will be the "},{"code":"Response","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"regardless of whether the "},{"code":"Response","type":"codeVoice"},{"type":"text","text":" was inlined or found in the "},{"code":"Components","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Example:","type":"text"}]}]},{"type":"codeListing","code":["let foundResponse: OpenAPI.Response","foundResponse = document.components.lookup(successResponse)!"],"syntax":null}]}],"identifier":{"url":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Operation\/responses","interfaceLanguage":"swift"},"references":{"doc://OpenAPIKit/documentation/OpenAPIKit/OpenAPI":{"identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI","type":"topic","title":"OpenAPI","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OpenAPI"}],"role":"symbol","abstract":[{"type":"text","text":"The OpenAPI namespace"}],"url":"\/documentation\/openapikit\/openapi","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"OpenAPI"}]},"doc://OpenAPIKit/documentation/OpenAPIKit/OpenAPI/Operation/responses":{"url":"\/documentation\/openapikit\/openapi\/operation\/responses","fragments":[{"text":"var"