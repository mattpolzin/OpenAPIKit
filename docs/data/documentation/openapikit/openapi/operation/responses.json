nAPI.Response.StatusCode, Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>)","firstResponse = operation.responses[0]!","","\/\/ literally documented as \"200\" status code:","let successResponse: Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>","successResponse = operation.responses[status: 200]!","","\/\/ documented as \"2XX\" status code:","let successResponse2: Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>","successResponse2 = operation.responses[.range(.success)]!"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"text":"If you want to access the response (assuming it is inlined) you need to grab","type":"text"},{"text":" ","type":"text"},{"text":"it out of the ","type":"text"},{"code":"Either","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Example:"}]}],"type":"paragraph"},{"code":["let inlinedResponse = successResponse.responseValue"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"text":"You can also look the response up in the ","type":"text"},{"code":"Components","type":"codeVoice"},{"text":". For convenience, you","type":"text"},{"text":" ","type":"text"},{"text":"can ask to have the ","type":"text"},{"code":"Either","type":"codeVoice"},{"text":" looked up and the result will be the ","type":"text"},{"code":"Response","type":"codeVoice"},{"text":" ","type":"text"},{"text":"regardless of whether the ","type":"text"},{"code":"Response","type":"codeVoice"},{"text":" was inlined or found in the ","type":"text"},{"code":"Components","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Example:","type":"text"}],"type":"strong"}],"type":"paragraph"},{"code":["let foundResponse: OpenAPI.Response","foundResponse = document.components.lookup(successResponse)!"],"syntax":null,"type":"codeListing"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/OpenAPIKit\