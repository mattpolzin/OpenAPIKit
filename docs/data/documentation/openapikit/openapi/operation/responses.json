{"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit","doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI","doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Operation"]]},"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"responses","kind":"identifier"},{"text":": ","kind":"text"},{"text":"OpenAPI","preciseIdentifier":"s:10OpenAPIKit0A3APIO","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Response","preciseIdentifier":"s:10OpenAPIKit0A3APIO8ResponseV","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Response","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Map","preciseIdentifier":"s:10OpenAPIKit0A3APIO8ResponseV3Mapa","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Response\/Map","kind":"typeIdentifier"}],"languages":["swift"],"platforms":["Linux"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"The status code keys can be integer values, ranges, or even the","type":"text"},{"text":" ","type":"text"},{"code":"default","type":"codeVoice"},{"text":" which just refers to the response to expect where no","type":"text"},{"text":" ","type":"text"},{"text":"other respones apply.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Because the map is ordered, you can access responses by either","type":"text"},{"text":" ","type":"text"},{"text":"status code or index. Notice that the values of this dictionary are actually","type":"text"},{"text":" ","type":"text"},{"code":"Either","type":"codeVoice"},{"text":" an inline ","type":"text"},{"code":"Response","type":"codeVoice"},{"text":" or a reference to a ","type":"text"},{"code":"Response","type":"codeVoice"},{"text":" that is","type":"text"},{"text":" ","type":"text"},{"text":"defined elsewhere.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Example:"}],"type":"strong"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["let firstResponse: (OpenAPI.Response.StatusCode, Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>)","firstResponse = operation.responses[0]!","","\/\/ literally documented as \"200\" status code:","let successResponse: Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>","successResponse = operation.responses[status: 200]!","","\/\/ documented as \"2XX\" status code:","let successResponse2: Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>","successResponse2 = operation.responses[.range(.success)]!"]},{"inlineContent":[{"text":"If you want to access the response (assuming it is inlined) you need to grab","type":"text"},{"text":" ","type":"text"},{"text":"it out of the ","type":"text"},{"type":"codeVoice","code":"Either"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Example:","type":"text"}]}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["let inlinedResponse = successResponse.responseValue"]},{"inlineContent":[{"type":"text","text":"You can also look the response up in the "},{"type":"codeVoice","code":"Components"},{"type":"text","text":". For convenience, you"},{"type":"text","text":" "},{"type":"text","text":"can ask to have the "},{"type":"codeVoice","code":"Either"},{"type":"text","text":" looked up and the result will be the "},{"type":"codeVoice","code":"Response"},{"type":"text","text":" "},{"type":"text","text":"regardless of whether the "},{"type":"codeVoice","code":"Response"},{"type":"text","text":" was inlined or found in the "},{"type":"codeVoice","code":"Components"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","tex