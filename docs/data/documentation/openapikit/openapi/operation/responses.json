{"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"responses","kind":"identifier"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI","text":"OpenAPI","kind":"typeIdentifier","preciseIdentifier":"s:10OpenAPIKit0A3APIO"},{"text":".","kind":"text"},{"preciseIdentifier":"s:10OpenAPIKit0A3APIO8ResponseV","text":"Response","kind":"typeIdentifier","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Response"},{"text":".","kind":"text"},{"preciseIdentifier":"s:10OpenAPIKit0A3APIO8ResponseV3Mapa","text":"Map","kind":"typeIdentifier","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Response\/Map"}],"platforms":["Linux"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"text":"The status code keys can be integer values, ranges, or even the","type":"text"},{"text":" ","type":"text"},{"code":"default","type":"codeVoice"},{"text":" which just refers to the response to expect where no","type":"text"},{"text":" ","type":"text"},{"text":"other respones apply.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Because the map is ordered, you can access responses by either"},{"type":"text","text":" "},{"type":"text","text":"status code or index. Notice that the values of this dictionary are actually"},{"type":"text","text":" "},{"code":"Either","type":"codeVoice"},{"type":"text","text":" an inline "},{"code":"Response","type":"codeVoice"},{"type":"text","text":" or a reference to a "},{"code":"Response","type":"codeVoice"},{"type":"text","text":" that is"},{"type":"text","text":" "},{"type":"text","text":"defined elsewhere."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Example:"}],"type":"strong"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["let firstResponse: (OpenAPI.Response.StatusCode, Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>)","firstResponse = operation.responses[0]!","","\/\/ literally documented as \"200\" status code:","let successResponse: Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>","successResponse = operation.responses[status: 200]!","","\/\/ documented as \"2XX\" status code:","let successResponse2: Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>","successResponse2 = operation.responses[.range(.success)]!"]},{"inlineContent":[{"text":"If you want to access the response (assuming it is inlined) you need to grab","type":"text"},{"text":" ","type":"text"},{"text":"it out of the ","type":"text"},{"code":"Either","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Example:","type":"text"}]}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["let inlinedResponse = successResponse.responseValue"]},{"inlineContent":[{"text":"You can also look the response up in the ","type":"text"},{"code":"Components","type":"codeVoice"},{"text":". For convenience, you","type":"text"},{"text":" ","type":"text"},{"text":"can ask to have the ","type":"text"},{"code":"Either","type":"codeVoice"},{"text":" looked up and the result will be the ","type":"text"},{"code":"Response","type":"codeVoice"},{"text":" ","type":"text"},{"text":"regardless of whether the ","type":"text"},{"code":"Response","type":"codeVoice"},{"text":" was inlined or found in the ","type":"text"},{"code":"Components","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Example:"}]}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["let foundResponse: OpenAPI.Response","foundResponse = document.components.lookup(successResponse)!"]}],"kind":"content"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openapikit\/openapi\/operation\/responses"]}],"hierarchy":{"paths":[["doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit","doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI","doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Operation"]]},"identifier":{"url":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Operation\/responses","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"The possible responses for this operation, keyed by status code."}],"kind":"symbol","metadata":{"symbolKind":"property","modules":[{"name":"OpenAPIKit"}],"roleHeading":"Instance Property","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"responses","kind":"identifier"},{"text":": ","kind":"text"},{"text":"OpenAPI","preciseIdentifier":"s:10OpenAPIKit0A3APIO","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Response","preciseIdentifier":"s:10OpenAPIKit0A3APIO8ResponseV","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Map","preciseIdentifier":"s:10OpenAPIKit0A3APIO8ResponseV3Mapa","kind":"typeIdentifier"}],"title":"responses","role":"symbol","externalID":"s:10OpenAPIKit0A3APIO9OperationV9responses0aB4Core17OrderedDictionaryVyAG6SharedO18ResponseStatusCodeVAG6EitherOyAC9ReferenceVy_AC0J0VGASGGvp"},"references":{"doc://OpenAPIKit/documentation/OpenAPIKit/OpenAPI":{"identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI","abstract":[{"text":"The OpenAPI namespace","type":"text"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OpenAPI"}],"url":"\/documentation\/openapikit\/openapi","kind":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OpenAPI"}],"title":"OpenAPI","type":"topic"},"doc://OpenAPIKit/documentation/OpenAPIKit/OpenAPI/Response/Map":{"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"Map"}],"url":"\/documentation\/openap