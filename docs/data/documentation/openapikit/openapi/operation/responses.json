{"sections":[],"abstract":[{"text":"The possible responses for this operation, keyed by status code.","type":"text"}],"metadata":{"roleHeading":"Instance Property","modules":[{"name":"OpenAPIKit"}],"role":"symbol","symbolKind":"property","externalID":"s:10OpenAPIKit0A3APIO9OperationV9responses0aB4Core17OrderedDictionaryVyAG6SharedO18ResponseStatusCodeVAG6EitherOyAC9ReferenceVy_AC0J0VGASGGvp","title":"responses","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"responses"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10OpenAPIKit0A3APIO","kind":"typeIdentifier","text":"OpenAPI"},{"kind":"text","text":"."},{"preciseIdentifier":"s:10OpenAPIKit0A3APIO8ResponseV","kind":"typeIdentifier","text":"Response"},{"kind":"text","text":"."},{"preciseIdentifier":"s:10OpenAPIKit0A3APIO8ResponseV3Mapa","kind":"typeIdentifier","text":"Map"}]},"kind":"symbol","variants":[{"paths":["\/documentation\/openapikit\/openapi\/operation\/responses"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Operation\/responses"},"hierarchy":{"paths":[["doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit","doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI","doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Operation"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"responses"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"OpenAPI","preciseIdentifier":"s:10OpenAPIKit0A3APIO","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Response","preciseIdentifier":"s:10OpenAPIKit0A3APIO8ResponseV","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Response"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Map","preciseIdentifier":"s:10OpenAPIKit0A3APIO8ResponseV3Mapa","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Response\/Map"}],"languages":["swift"],"platforms":["Linux"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The status code keys can be integer values, ranges, or even the"},{"type":"text","text":" "},{"code":"default","type":"codeVoice"},{"type":"text","text":" which just refers to the response to expect where no"},{"type":"text","text":" "},{"type":"text","text":"other respones apply."}]},{"type":"paragraph","inlineContent":[{"text":"Because the map is ordered, you can access responses by either","type":"text"},{"text":" ","type":"text"},{"text":"status code or index. Notice that the values of this dictionary are actually","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Either"},{"text":" an inline ","type":"text"},{"type":"codeVoice","code":"Response"},{"text":" or a reference to a ","type":"text"},{"type":"codeVoice","code":"Response"},{"text":" that is","type":"text"},{"text":" ","type":"text"},{"text":"defined elsewhere.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Example:"}],"type":"strong"}]},{"code":["let firstResponse: (OpenAPI.Response.StatusCode, Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>)","firstResponse = operation.responses[0]!","","\/\/ literally documented as \"200\" status code:","let successResponse: Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>","successResponse = operation.responses[status: 200]!","","\/\/ documented as \"2XX\" status code:","let successResponse2: Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>","successResponse2 = operation.responses[.range(.success)]!"],"type":"codeListing","syntax":null},{"type":"paragraph","inlineContent":[{"text":"If you want to access the response (assuming it is inlined) you need to grab","type":"text"},{"text":" ","type":"text"},{"text":"it out of the ","type":"text"},{"code":"Either","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Example:","type":"text"}]}]},{"code":["let inlinedResponse = successResponse.responseValue"],"type":"codeListing","syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also look the response up in the "},{"code":"Components","type":"codeVoice"},{"type":"text","text":". For convenience, you"},{"type":"text","text":" "},{"type":"text","text":"can ask to have the "},{"code":"Either","type":"codeVoice"},{"type":"text","text":" looked up and the result will be the "},{"code":"Response","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"regardless of whether the "},{"code":"Response","type":"codeVoice"},{"type":"text","text":" was inlined or found in the "},{"code":"Components","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Example:"}]}]},{"code":["let foundResponse: OpenAPI.Response","foundResponse = document.components.lookup(successResponse)!"],"type":"codeListing","syntax":null}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://OpenAPIKit/documentation/OpenAPIKit/OpenAPI/Operation/responses":{"kind":"symbol","url":"\/documentation\/openapikit\/openapi\/operation\/responses","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"responses"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10OpenAPIKit0A3APIO","kind":"typeIdentifier","text":"OpenAPI"},{"kind":"text","text":"."},{"preciseIdentifier":"s:10OpenAPIKit0A3APIO8ResponseV","kind":"typeIdentifier","text":"Response"},{"kind":"text","text":"."},{"preciseIdentifier":"s:10OpenAPIKit0A3APIO8ResponseV3Mapa","kind":"typeIdentifier","text":"Map