{"hierarchy":{"paths":[["doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit","doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI","doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Operation"]]},"kind":"symbol","sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"responses"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"OpenAPI","preciseIdentifier":"s:10OpenAPIKit0A3APIO","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Response","preciseIdentifier":"s:10OpenAPIKit0A3APIO8ResponseV","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Response"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Map","preciseIdentifier":"s:10OpenAPIKit0A3APIO8ResponseV3Mapa","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Response\/Map"}],"platforms":["Linux"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The status code keys can be integer values, ranges, or even the"},{"type":"text","text":" "},{"type":"codeVoice","code":"default"},{"type":"text","text":" which just refers to the response to expect where no"},{"type":"text","text":" "},{"type":"text","text":"other respones apply."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because the map is ordered, you can access responses by either"},{"type":"text","text":" "},{"type":"text","text":"status code or index. Notice that the values of this dictionary are actually"},{"type":"text","text":" "},{"type":"codeVoice","code":"Either"},{"type":"text","text":" an inline "},{"type":"codeVoice","code":"Response"},{"type":"text","text":" or a reference to a "},{"type":"codeVoice","code":"Response"},{"type":"text","text":" that is"},{"type":"text","text":" "},{"type":"text","text":"defined elsewhere."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Example:","type":"text"}],"type":"strong"}]},{"syntax":null,"type":"codeListing","code":["let firstResponse: (OpenAPI.Response.StatusCode, Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>)","firstResponse = operation.responses[0]!","","\/\/ literally documented as \"200\" status code:","let successResponse: Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>","successResponse = operation.responses[status: 200]!","","\/\/ documented as \"2XX\" status code:","let successResponse2: Either<OpenAPI.Reference<OpenAPI.Response>, OpenAPI.Response>","successResponse2 = operation.responses[.range(.success)]!"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to access the response (assuming it is inlined) you need to grab"},{"type":"text","text":" "},{"type":"text","text":"it out of the "},{"type":"codeVoice","code":"Either"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Example:"}],"type":"strong"}]},{"syntax":null,"type":"codeListing","code":["let inlinedResponse = successResponse.responseValue"]},{"type":"paragraph","inlineContent":[{"text":"You can also look the response up in the ","type":"text"},{"code":"Components","type":"codeVoice"},{"text":". For convenience, you","type":"text"},{"text":" ","type":"text"},{"text":"can ask to have the ","type":"text"},{"code":"Either","type":"codeVoice"},{"text":" looked up and the result will be the ","type":"text"},{"code":"Response","type":"codeVoice"},{"text":" ","type":"text"},{"text":"regardless of whether the ","type":"text"},{"code":"Response","type":"codeVoice"},{"text":" was inlined or found in the ","type":"text"},{"code":"Components","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Example:","type":"text"}]}]},{"syntax":null,"type":"codeListing","code":["let foundResponse: OpenAPI.Response","foundResponse = document.components.lookup(successResponse)!"]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Operation\/responses"},"metadata":{"roleHeading":"Instance Property","title":"responses","modules":[{"name":"OpenAPIKit"}],"externalID":"s:10OpenAPIKit0A3APIO9OperationV9responses0aB4Core17OrderedDictionaryVyAG6SharedO18ResponseStatusCodeVAG6EitherOyAC9ReferenceVy_AC0J0VGASGGvp","role":"symbol","symbolKind":"property","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"responses","kind":"identifier"},{"text":": ","kind":"text"},{"text":"OpenAPI","kind":"typeIdentifier","preciseIdentifier":"s:10OpenAPIKit0A3APIO"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Response","preciseIdentifier":"s:10OpenAPIKit0A3APIO8ResponseV"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Map","preciseIdentifier":"s:10OpenAPIKit0A3APIO8ResponseV3Mapa"}]},"abstract":[{"text":"The possible responses for this operation, keyed by status code.","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openapikit\/openapi\/operation\/responses"]}],"references":{"doc://OpenAPIKit/documentation/OpenAPIKit/OpenAPI/Operation":{"type":"topic","kind":"symbol","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/OpenAPI\/Operation","title":"OpenAPI.Operation","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Operation"}],"navigatorTitle":[{"kind":"identifier","text":"Operation"}],"url":"\/documentation\/openapikit\/openapi\/operation","abstract":[{"type":"text","text":"OpenAPI Spec “Operation Object”"}],"role":"symbol"},"doc://OpenAPIKit/documentation/OpenAPIKit/OpenAPI/Response":{"url":"\/documentation\/openapikit\/openapi\/r