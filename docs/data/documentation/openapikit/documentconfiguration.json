{"metadata":{"externalID":"s:10OpenAPIKit21DocumentConfigurationO","fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DocumentConfiguration"}],"roleHeading":"Enumeration","title":"DocumentConfiguration","navigatorTitle":[{"kind":"identifier","text":"DocumentConfiguration"}],"role":"symbol","symbolKind":"enum","modules":[{"name":"OpenAPIKit"}]},"abstract":[{"type":"text","text":"OpenAPIKit supports some additional Encoder\/Decoder configuration above and beyond"},{"type":"text","text":" "},{"type":"text","text":"what the Encoder or Decoder support out of box."}],"topicSections":[{"title":"Type Properties","identifiers":["doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/DocumentConfiguration\/versionMapKey"]}],"hierarchy":{"paths":[["doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/DocumentConfiguration"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openapikit\/documentconfiguration"]}],"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["Linux"],"languages":["swift"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DocumentConfiguration","kind":"identifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"To instruct OpenAPIKit to decode OpenAPI Standards versions it does not","type":"text"},{"text":" ","type":"text"},{"text":"natively support, set ","type":"text"},{"code":"userInfo[DocumentConfiguration.versionMapKey] = [\"3.5.0\": OpenAPI.Document.Version.v3_1_1]","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"That will cause OpenAPIKit to accept OAS v3.5.0 on decode and treat it as","type":"text"},{"text":" ","type":"text"},{