{"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"topicSections":[{"title":"Type Properties","identifiers":["doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/DocumentConfiguration\/versionMapKey"]}],"metadata":{"roleHeading":"Enumeration","role":"symbol","navigatorTitle":[{"text":"DocumentConfiguration","kind":"identifier"}],"symbolKind":"enum","title":"DocumentConfiguration","modules":[{"name":"OpenAPIKit"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DocumentConfiguration","kind":"identifier"}],"externalID":"s:10OpenAPIKit21DocumentConfigurationO"},"identifier":{"url":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/DocumentConfiguration","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit"]]},"variants":[{"paths":["\/documentation\/openapikit\/documentconfiguration"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","abstract":[{"text":"OpenAPIKit supports some additional Encoder\/Decoder configuration above and beyond","type":"text"},{"text":" ","type":"text"},{"text":"what the Encoder or Decoder support out of box.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["Linux"],"languages":["swift"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DocumentConfiguration","kind":"identifier"}]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"To instruct OpenAPIKit to decode OpenAPI Standards versions it does not"},{"type":"text","text":" "},{"type":"text","text":"natively support, set "},{"code":"userInfo[DocumentConfiguration.versionMapKey] = [\"3.5.0\": OpenAPI.Document.Version.v3_1_1]","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"That will cause OpenAPIKit to accept OAS v3.5.0 on decode and treat it as"},{"type":"text","text":" "},{"