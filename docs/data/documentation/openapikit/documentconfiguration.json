{"abstract":[{"type":"text","text":"OpenAPIKit supports some additional Encoder\/Decoder configuration above and beyond"},{"type":"text","text":" "},{"type":"text","text":"what the Encoder or Decoder support out of box."}],"identifier":{"url":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/DocumentConfiguration","interfaceLanguage":"swift"},"topicSections":[{"identifiers":["doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/DocumentConfiguration\/versionMapKey"],"title":"Type Properties"}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["Linux"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DocumentConfiguration","kind":"identifier"}]}]},{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"To instruct OpenAPIKit to decode OpenAPI Standards versions it does not","type":"text"},{"text":" ","type":"text"},{"text":"natively support, set ","type":"text"},{"type":"codeVoice","code":"userInfo[DocumentConfiguration.versionMapKey] = [\"3.5.0\": OpenAPI.Document.Version.v3_1_1]"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"That will cause OpenAPIKit to accept OAS v3.5.0 on decode and treat it as"},{"type":"text","text":" "},{"type":"text","text":"the natively supported v3.1.1. This feature exists to allow OpenAPIKit to"},{"type":"text","text":" "},{"type":"text","text":"be configured to parse future versions of the OAS standard that are"},{"type":"text","text":" "},{"type":"text","text":"determined (by you) to be backwards compatible with a previous version"},{"type":"text","text":" "},{"type":"text","text":"prior to OpenAPIKit gaining official support for the new version and its"},{"type":"text","text":" "},{"type":"text","text":"features."}]}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","metadata":{"externalID":"s:10OpenAPIKit21DocumentConfigurationO","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DocumentConfiguration","kind":"identifier"}],"symbolKind":"enum","modules":[{"name":"OpenAPIKit"}],"role":"symbol","roleHeading":"Enumeration","navigatorTitle":[{"text":"DocumentConfiguration","kind":"identifier"}],"title":"DocumentConfiguration"},"hierarchy":{"paths":[["doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit"]]},"variants":[{"paths":["\/documentation\/openapikit\/documentconfiguration"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OpenAPIKit/documentation/OpenAPIKit/DocumentConfiguration/versionMapKey":{"title":"versionMapKey","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"versionMapKey","kind":"identifier"},{"text":": ","kind":"text"},{"text":"CodingUserInfoKey","kind":"typeIdentifier","preciseIdentifier":"s:s17CodingUserInfoKeyV"}],"identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/DocumentConfiguration\/versionMapKey","url":"\/documentation\/openapikit\/documentconfiguration\/versionmapkey","role":"symbol","type":"topic","kind":"symbol","abstract":[]},"doc://OpenAPIKit/documentation/OpenAPIKit/DocumentConfiguration":{"title":"DocumentConfiguration","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DocumentConfiguration","kind":"identifier"}],"identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/DocumentConfiguration","url":"\/documentation\/openapikit\/documentconfiguration","role":"symbol","type":"topic","kind":"symbol","abstract":[{"text":"OpenAPIKit supports some additional Encoder\/Decoder configuration above and beyond","type":"text"},{"text":" ","type":"text"},{"text":"what the Encoder or Decoder support out of box.","type":"text"}],"navigatorTitle":[{"text":"DocumentConfiguration","kind":"identifier"}]},"doc://OpenAPIKit/documentation/OpenAPIKit":{"identifier":"doc:\/\/OpenAPIKit\/