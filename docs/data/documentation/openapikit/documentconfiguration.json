{"abstract":[{"type":"text","text":"OpenAPIKit supports some additional Encoder\/Decoder configuration above and beyond"},{"type":"text","text":" "},{"type":"text","text":"what the Encoder or Decoder support out of box."}],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/openapikit\/documentconfiguration"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit"]]},"metadata":{"navigatorTitle":[{"kind":"identifier","text":"DocumentConfiguration"}],"externalID":"s:10OpenAPIKit21DocumentConfigurationO","modules":[{"name":"OpenAPIKit"}],"title":"DocumentConfiguration","symbolKind":"enum","role":"symbol","roleHeading":"Enumeration","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"DocumentConfiguration"}]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["Linux"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"DocumentConfiguration"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"To instruct OpenAPIKit to decode OpenAPI Standards versions it does not"},{"type":"text","text":" "},{"type":"text","text":"natively support, set "},{"type":"codeVoice","code":"userInfo[DocumentConfiguration.versionMapKey] = [\"3.5.0\": OpenAPI.Document.Version.v3_1_1]"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"That will cause OpenAPIKit to accept OAS v3.5.0 on decode and treat it as","type":"text"},{"text":" ","type":"text"},{"text":"the natively supported v3.1.1. This feature exists to allow OpenAPIKit to","type":"text"},{"text":" ","type":"text"},{"text":"be configured to parse future versions of the OAS standard that are","type":"text"},{"text":" ","type":"text"},{"text":"determined (by you) to be backwards compatible with a previous version","type":"text"},{"text":" ","type":"text"},{"text":"prior to OpenAPIKit gaining official support for the new version and its","type":"text"},{"text":" ","type":"text"},{"text":"features.","type":"text"}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/DocumentConfiguration","interfaceLanguage":"swift"},"topicSections":[{"title":"Type Properties","identifiers":["doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/DocumentConfiguration\/versionMapKey"]}],"references":{"doc://OpenAPIKit/documentation/OpenAPIKit":{"identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit","title":"OpenAPIKit","url":"\/documentation\/openapikit","type":"topic","kind":"symbol","abstract":[],"role":"collection"},"doc://OpenAPIKit/documentation/OpenAPIKit/DocumentConfiguration/versionMapKey":{"url":"\/documentation\/openapikit\/documentconfiguration\/versionmapkey","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/DocumentConfiguration\/versionMapKey","abstract":[],"role":"symbol","title":"versionMapKey","kind":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"versionMapKey"},{"text":": ","kind":"text"},{"text":"CodingUserInfoKey","kind":"typeIdentifier","preciseIdentifier":"s:s17CodingUserInfoKeyV"}],"type":"topic"},"doc://OpenAPIKit/documentation/OpenAPIKit/DocumentConfiguration":{"abstract":[{"text":"OpenAPIKit supports some additional Encoder\/Decoder configuration above and beyond","type":"text"},{"text":" ","type":"text"},{"text":"what the Encoder or Decoder support out of box.","type":"text"}],"type":"topic","url":"\/documentation\/openapikit\/documentconfiguration","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"DocumentConfiguration"}],"title":"DocumentConfiguration","role":"symbol","identifier":"doc:\/\/OpenAPIKit\/documentation\/OpenAPIKit\/DocumentConfiguration","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"DocumentConfiguration"}]}}}